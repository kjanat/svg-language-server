{
	"prettier": { "allowed": false },
	"formatter": [{ "external": { "command": "dprint", "arguments": ["fmt", "--stdin", "{buffer_path}"] } }],
	"languages": {
		"Rust": { "wrap_guides": [100] },
		"TypeScript": { "language_servers": ["deno", "!typescript-language-server", "!tsgo", "!vtsls"] }
	},
	"lsp": {
		"rust-analyzer": {
			"initialization_options": {
				"cargo": {
					"allTargets": true,
					"features": "all"
				}
			}
		},
		"deno": {
			"settings": {
				"deno": {
					"enable": true
				}
			}
		}
	}
}
