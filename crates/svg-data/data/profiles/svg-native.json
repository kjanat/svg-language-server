	"coverage_gaps": [
		{
			"reason": "Lists attribute GROUPS by prose name (aria / conditional-processing / core except id / event-attribute families / deprecated xlink). These are not individual SVG attribute names; expanding them needs a curated group→names map, deferred.",
			"section": "commonattributes"
		},
		{
			"reason": "Captures every explicitly-marked text/font element & property, but the prose phrase \"the subproperties of 'font-variant'\" denotes additional names not spelled out literally; those sub-properties are not individually enumerated.",
			"section": "text"
		}
