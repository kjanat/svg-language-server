{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "CategoriesFile",
	"description": "Typed payload for `categories.json`.",
	"type": "object",
	"properties": {
		"attribute_categories": {
			"description": "Attribute-category memberships.",
			"type": "array",
			"items": {
				"$ref": "#/$defs/AttributeCategoryMembership"
			}
		},
		"element_categories": {
			"description": "Element-category memberships.",
			"type": "array",
			"items": {
				"$ref": "#/$defs/ElementCategoryMembership"
			}
		},
		"schema_version": {
			"description": "Schema version for the category payload.",
			"type": "integer",
			"format": "uint32",
			"minimum": 0
		}
	},
	"required": [
		"schema_version",
		"element_categories",
		"attribute_categories"
	],
	"$defs": {
		"AttributeCategoryMembership": {
			"description": "Category membership for one attribute.",
			"type": "object",
			"properties": {
				"attribute": {
					"description": "Attribute name.",
					"type": "string"
				},
				"category": {
					"description": "Category id.",
					"type": "string"
				},
				"provenance": {
					"description": "Supporting provenance.",
					"type": "array",
					"items": {
						"$ref": "#/$defs/FactProvenance"
					}
				}
			},
			"required": [
				"attribute",
				"category",
				"provenance"
			]
		},
		"ElementCategoryMembership": {
			"description": "Category membership for one element.",
			"type": "object",
			"properties": {
				"category": {
					"description": "Category id.",
					"type": "string"
				},
				"element": {
					"description": "Element name.",
					"type": "string"
				},
				"provenance": {
					"description": "Supporting provenance.",
					"type": "array",
					"items": {
						"$ref": "#/$defs/FactProvenance"
					}
				}
			},
			"required": [
				"element",
				"category",
				"provenance"
			]
		},
		"ExtractionConfidence": {
			"description": "Confidence attached to an extracted fact.",
			"oneOf": [
				{
					"description": "Parsed from a structured authoritative source.",
					"type": "string",
					"const": "exact"
				},
				{
					"description": "Derived from a reliable but indirect source.",
					"type": "string",
					"const": "derived"
				},
				{
					"description": "Human-curated fallback.",
					"type": "string",
					"const": "manual"
				}
			]
		},
		"FactProvenance": {
			"description": "Provenance attached to a normalized fact.",
			"type": "object",
			"properties": {
				"confidence": {
					"description": "Extraction confidence classification.",
					"$ref": "#/$defs/ExtractionConfidence"
				},
				"locator": {
					"description": "Concrete source locator within the pinned input.",
					"$ref": "#/$defs/SourceLocator"
				},
				"pin": {
					"description": "Exact pinned location for the source.",
					"$ref": "#/$defs/SourcePin"
				},
				"source_id": {
					"description": "Source input id from the pinned manifest.",
					"type": "string"
				},
				"source_kind": {
					"description": "Kind of source material used for extraction.",
					"$ref": "#/$defs/ProvenanceSourceKind"
				}
			},
			"required": [
				"source_id",
				"source_kind",
				"pin",
				"locator",
				"confidence"
			]
		},
		"ProvenanceSourceKind": {
			"description": "Source material used for a normalized fact.",
			"oneOf": [
				{
					"description": "W3C TR or editor's draft chapter HTML.",
					"type": "string",
					"const": "html"
				},
				{
					"description": "Element or attribute index page.",
					"type": "string",
					"const": "index"
				},
				{
					"description": "Flattened DTD or DTD-derived source.",
					"type": "string",
					"const": "dtd"
				},
				{
					"description": "`definitions.xml` or companion definitions file.",
					"type": "string",
					"const": "definitions_xml"
				},
				{
					"description": "Manual curated note.",
					"type": "string",
					"const": "manual_review"
				}
			]
		},
		"SourceLocator": {
			"description": "Exact location inside a pinned source.",
			"oneOf": [
				{
					"description": "HTML fragment id.",
					"type": "object",
					"properties": {
						"anchor": {
							"description": "Fragment id or anchor name.",
							"type": "string"
						},
						"kind": {
							"type": "string",
							"const": "fragment"
						}
					},
					"required": [
						"kind",
						"anchor"
					]
				},
				{
					"description": "Structured definition in a file.",
					"type": "object",
					"properties": {
						"file": {
							"description": "File path relative to the pinned source root.",
							"type": "string"
						},
						"id": {
							"description": "Definition id within the file.",
							"type": "string"
						},
						"kind": {
							"type": "string",
							"const": "definition"
						}
					},
					"required": [
						"kind",
						"file",
						"id"
					]
				},
				{
					"description": "Specific line range in a text file.",
					"type": "object",
					"properties": {
						"end_line": {
							"description": "Inclusive ending 1-based line number.",
							"type": "integer",
							"format": "uint32",
							"minimum": 1
						},
						"file": {
							"description": "File path relative to the pinned source root.",
							"type": "string"
						},
						"kind": {
							"type": "string",
							"const": "line_range"
						},
						"start_line": {
							"description": "Starting 1-based line number.",
							"type": "integer",
							"format": "uint32",
							"minimum": 1
						}
					},
					"required": [
						"kind",
						"file",
						"start_line",
						"end_line"
					]
				}
			]
		},
		"SourcePin": {
			"description": "Exact pin used to make source fetching reproducible.",
			"oneOf": [
				{
					"description": "Pinned absolute URL.",
					"type": "object",
					"properties": {
						"kind": {
							"type": "string",
							"const": "url"
						},
						"url": {
							"description": "Canonical source URL.",
							"type": "string"
						}
					},
					"required": [
						"kind",
						"url"
					]
				},
				{
					"description": "Pinned repository commit and optional path.",
					"type": "object",
					"properties": {
						"commit": {
							"description": "Exact commit hash.",
							"type": "string"
						},
						"kind": {
							"type": "string",
							"const": "git_commit"
						},
						"path": {
							"description": "Optional path within the repo.",
							"type": [
								"string",
								"null"
							]
						},
						"repository": {
							"description": "Repository URL.",
							"type": "string"
						}
					},
					"required": [
						"kind",
						"repository",
						"commit"
					]
				}
			]
		}
	}
}
