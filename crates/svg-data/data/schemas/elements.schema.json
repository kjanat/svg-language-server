{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Array_of_SnapshotElementRecord",
	"type": "array",
	"items": {
		"$ref": "#/$defs/SnapshotElementRecord"
	},
	"$defs": {
		"ElementContentModel": {
			"description": "Structured element content model.",
			"oneOf": [
				{
					"description": "Element must be empty.",
					"type": "object",
					"properties": {
						"kind": {
							"type": "string",
							"const": "empty"
						}
					},
					"required": [
						"kind"
					]
				},
				{
					"description": "Element primarily contains text nodes.",
					"type": "object",
					"properties": {
						"kind": {
							"type": "string",
							"const": "text_only"
						}
					},
					"required": [
						"kind"
					]
				},
				{
					"description": "Element accepts any SVG child element.",
					"type": "object",
					"properties": {
						"kind": {
							"type": "string",
							"const": "any_svg"
						}
					},
					"required": [
						"kind"
					]
				},
				{
					"description": "Element accepts children from listed categories.",
					"type": "object",
					"properties": {
						"categories": {
							"description": "Category ids allowed as children.",
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"kind": {
							"type": "string",
							"const": "category_set"
						}
					},
					"required": [
						"kind",
						"categories"
					]
				},
				{
					"description": "Element accepts a fixed set of child element names.",
					"type": "object",
					"properties": {
						"elements": {
							"description": "Child element names allowed in the snapshot.",
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"kind": {
							"type": "string",
							"const": "element_set"
						}
					},
					"required": [
						"kind",
						"elements"
					]
				},
				{
					"description": "Element accepts foreign-namespace content.",
					"type": "object",
					"properties": {
						"kind": {
							"type": "string",
							"const": "foreign_namespace"
						}
					},
					"required": [
						"kind"
					]
				}
			]
		},
		"ExtractionConfidence": {
			"description": "Confidence attached to an extracted fact.",
			"oneOf": [
				{
					"description": "Parsed from a structured authoritative source.",
					"type": "string",
					"const": "exact"
				},
				{
					"description": "Derived from a reliable but indirect source.",
					"type": "string",
					"const": "derived"
				},
				{
					"description": "Human-curated fallback.",
					"type": "string",
					"const": "manual"
				}
			]
		},
		"FactProvenance": {
			"description": "Provenance attached to a normalized fact.",
			"type": "object",
			"properties": {
				"confidence": {
					"description": "Extraction confidence classification.",
					"$ref": "#/$defs/ExtractionConfidence"
				},
				"locator": {
					"description": "Concrete source locator within the pinned input.",
					"$ref": "#/$defs/SourceLocator"
				},
				"pin": {
					"description": "Exact pinned location for the source.",
					"$ref": "#/$defs/SourcePin"
				},
				"source_id": {
					"description": "Source input id from the pinned manifest.",
					"type": "string"
				},
				"source_kind": {
					"description": "Kind of source material used for extraction.",
					"$ref": "#/$defs/ProvenanceSourceKind"
				}
			},
			"required": [
				"source_id",
				"source_kind",
				"pin",
				"locator",
				"confidence"
			]
		},
		"ProvenanceSourceKind": {
			"description": "Source material used for a normalized fact.",
			"oneOf": [
				{
					"description": "W3C TR or editor's draft chapter HTML.",
					"type": "string",
					"const": "html"
				},
				{
					"description": "Element or attribute index page.",
					"type": "string",
					"const": "index"
				},
				{
					"description": "Flattened DTD or DTD-derived source.",
					"type": "string",
					"const": "dtd"
				},
				{
					"description": "`definitions.xml` or companion definitions file.",
					"type": "string",
					"const": "definitions_xml"
				},
				{
					"description": "Manual curated note.",
					"type": "string",
					"const": "manual_review"
				}
			]
		},
		"SnapshotElementRecord": {
			"description": "Typed payload for `elements.json`.",
			"type": "object",
			"properties": {
				"attributes": {
					"description": "Attributes explicitly associated with the element.",
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"categories": {
					"description": "Category ids assigned to the element.",
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"content_model": {
					"description": "Typed content-model description.",
					"$ref": "#/$defs/ElementContentModel"
				},
				"name": {
					"description": "Element tag name.",
					"type": "string"
				},
				"provenance": {
					"description": "Source-backed provenance for this fact set.",
					"type": "array",
					"items": {
						"$ref": "#/$defs/FactProvenance"
					}
				},
				"title": {
					"description": "Human-readable title or description.",
					"type": "string"
				}
			},
			"required": [
				"name",
				"title",
				"categories",
				"content_model",
				"attributes",
				"provenance"
			]
		},
		"SourceLocator": {
			"description": "Exact location inside a pinned source.",
			"oneOf": [
				{
					"description": "HTML fragment id.",
					"type": "object",
					"properties": {
						"anchor": {
							"description": "Fragment id or anchor name.",
							"type": "string"
						},
						"kind": {
							"type": "string",
							"const": "fragment"
						}
					},
					"required": [
						"kind",
						"anchor"
					]
				},
				{
					"description": "Structured definition in a file.",
					"type": "object",
					"properties": {
						"file": {
							"description": "File path relative to the pinned source root.",
							"type": "string"
						},
						"id": {
							"description": "Definition id within the file.",
							"type": "string"
						},
						"kind": {
							"type": "string",
							"const": "definition"
						}
					},
					"required": [
						"kind",
						"file",
						"id"
					]
				},
				{
					"description": "Specific line range in a text file.",
					"type": "object",
					"properties": {
						"end_line": {
							"description": "Inclusive ending 1-based line number.",
							"type": "integer",
							"format": "uint32",
							"minimum": 1
						},
						"file": {
							"description": "File path relative to the pinned source root.",
							"type": "string"
						},
						"kind": {
							"type": "string",
							"const": "line_range"
						},
						"start_line": {
							"description": "Starting 1-based line number.",
							"type": "integer",
							"format": "uint32",
							"minimum": 1
						}
					},
					"required": [
						"kind",
						"file",
						"start_line",
						"end_line"
					]
				}
			]
		},
		"SourcePin": {
			"description": "Exact pin used to make source fetching reproducible.",
			"oneOf": [
				{
					"description": "Pinned absolute URL.",
					"type": "object",
					"properties": {
						"kind": {
							"type": "string",
							"const": "url"
						},
						"url": {
							"description": "Canonical source URL.",
							"type": "string"
						}
					},
					"required": [
						"kind",
						"url"
					]
				},
				{
					"description": "Pinned repository commit and optional path.",
					"type": "object",
					"properties": {
						"commit": {
							"description": "Exact commit hash.",
							"type": "string"
						},
						"kind": {
							"type": "string",
							"const": "git_commit"
						},
						"path": {
							"description": "Optional path within the repo.",
							"type": [
								"string",
								"null"
							]
						},
						"repository": {
							"description": "Repository URL.",
							"type": "string"
						}
					},
					"required": [
						"kind",
						"repository",
						"commit"
					]
				}
			]
		}
	}
}
