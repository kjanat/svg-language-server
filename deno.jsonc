{
	"workspace": {
		"members": ["./workers/*"],
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@1",
		"@std/html": "jsr:@std/html@1",
		"@std/http": "jsr:@std/http@1",
		"@std/media-types": "jsr:@std/media-types@1",
		"@std/path": "jsr:@std/path@1",
		"dreamcli": "jsr:@kjanat/dreamcli@2.4.0",
		"dreamcli/testkit": "jsr:@kjanat/dreamcli@2.4.0/testkit",
		"bcd": "npm:@mdn/browser-compat-data@7.3.11",
		"bun-types": "npm:bun-types@^1.3.14",
		"preact": "https://esm.sh/preact@10.23.1",
		"preact/": "https://esm.sh/preact@10.23.1/",
		"react": "https://esm.sh/preact@10.23.1/compat",
		"react/": "https://esm.sh/preact@10.23.1/compat/",
		"react-dom": "https://esm.sh/preact@10.23.1/compat",
		"preact-render-to-string": "https://esm.sh/preact-render-to-string@6",
		"web-features": "npm:web-features@3.23.0",
	},
	"fmt": { "exclude": ["**"] },
	"tasks": {
		"dev:all": "deno task --recursive dev",
		"fmt": {
			"command": "dprint fmt",
			"description": "Format the codebase using dprint.",
		},
	},
	"deploy": {
		"org": "kjanat",
		"app": "svg-compat",
		"install": "deno install",
		"runtime": { "entrypoint": "main.ts", "cwd": "workers/svg-compat/src" },
	},
	"exclude": ["./target", "./grammars"],
	"lint": {
		"rules": {
			"tags": ["recommended", "workspace"],
		},
	},
	"compilerOptions": { "checkJs": true, "strict": true },
	"nodeModulesDir": "none"
}
