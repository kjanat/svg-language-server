+#[gpui::test]
+async fn test_client_clipboard_code_action_hook(cx: &mut TestAppContext) {
+    init_test(cx, |_| {});
+
+    let data_uri = "data:image/svg+xml;base64,PHN2Zz48L3N2Zz4=";
+    let action = CodeAction {
+        server_id: lsp::LanguageServerId(0),
+        range: language::Anchor::MIN..language::Anchor::MIN,
+        lsp_action: LspAction::Command(lsp::Command {
+            title: "Copy SVG as data URI".into(),
+            command: CLIENT_COPY_TO_CLIPBOARD_COMMAND.into(),
+            arguments: Some(vec![json!({
+                "text": data_uri,
+                "label": "Copy SVG as data URI",
+                "kind": "svg-data-uri",
+                "mimeType": "image/svg+xml",
+            })]),
+        }),
+        resolved: true,
+    };
+
+    assert!(cx.update(|cx| handle_client_clipboard_code_action(&action, cx)));
+    assert_eq!(
+        cx.read_from_clipboard()
+            .and_then(|item| item.text().as_deref().map(str::to_string)),
+        Some(data_uri.to_string())
+    );
+}
