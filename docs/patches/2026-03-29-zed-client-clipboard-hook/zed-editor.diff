+pub(crate) const CLIENT_COPY_TO_CLIPBOARD_COMMAND: &str = "editor.copyToClipboard";
+
+pub(crate) fn handle_client_clipboard_code_action(action: &CodeAction, cx: &mut App) -> bool {
+    let command = match &action.lsp_action {
+        LspAction::Action(action) => action.command.as_ref(),
+        LspAction::Command(command) => Some(command),
+        LspAction::CodeLens(lens) => lens.command.as_ref(),
+    };
+    let Some(command) = command else {
+        return false;
+    };
+    if command.command != CLIENT_COPY_TO_CLIPBOARD_COMMAND {
+        return false;
+    }
+
+    let Some(text) = command
+        .arguments
+        .as_ref()
+        .and_then(|arguments| arguments.first())
+        .and_then(|argument| match argument {
+            Value::String(text) => Some(text.to_owned()),
+            Value::Object(payload) => payload
+                .get("text")
+                .and_then(Value::as_str)
+                .map(ToOwned::to_owned),
+            _ => None,
+        })
+    else {
+        return false;
+    };
+
+    cx.write_to_clipboard(ClipboardItem::new_string(text));
+    true
+}
