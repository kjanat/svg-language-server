{
	"name": "tree-sitter-svg-paint",
	"version": "0.0.1",
	"description": "SVG paint/color sub-grammar for Tree-sitter, injected into paint attribute values by tree-sitter-svg",
	"keywords": ["incremental", "parsing", "tree-sitter", "svg", "svg_paint"],
	"homepage": "https://github.com/kjanat/svg/tree/HEAD/grammars/tree-sitter-svg-paint#readme",
	"bugs": {
		"url": "https://github.com/kjanat/svg/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/svg.git",
		"directory": "grammars/tree-sitter-svg-paint"
	},
	"license": "MIT OR Apache-2.0",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"main": "bindings/node",
	"types": "bindings/node",
	"imports": {
		"#constants": "./constants.js"
	},
	"exports": {
		".": {
			"types": "./bindings/node/index.d.ts",
			"default": "./bindings/node/index.js"
		},
		"./package.json": "./package.json"
	},
	"directories": {
		"test": "test"
	},
	"files": [
		"/grammar.js",
		"/constants.js",
		"/binding.gyp",
		"/prebuilds/**",
		"/bindings/node/*",
		"/queries/*",
		"/scripts/*",
		"/src/**",
		"*.wasm"
	],
	"scripts": {
		"generate": "tree-sitter generate",
		"postinstall": "run -p setup:native setup:clangd-headers",
		"prestart": "tree-sitter build --wasm",
		"start": "tree-sitter playground --quiet",
		"test": "tree-sitter test && bun test",
		"test:corpus": "tree-sitter test",
		"test:grammar": "bun test grammar.test.ts",
		"test:node": "node --test bindings/node/*_test.js",
		"typecheck": "tsc --noEmit",
		"fmt": "dprint fmt",
		"lint": "biome check",
		"setup:native": "node scripts/ensure-native.ts",
		"setup:clangd-headers": "node scripts/ensure-clangd-headers.ts"
	},
	"dependencies": {
		"node-addon-api": "catalog:",
		"node-gyp-build": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/bun": "catalog:",
		"dprint": "catalog:",
		"node-gyp": "catalog:",
		"prebuildify": "catalog:",
		"runner-run": "catalog:",
		"tree-sitter": "catalog:",
		"tree-sitter-cli": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"tree-sitter": "catalog:"
	},
	"peerDependenciesMeta": {
		"tree-sitter": {
			"optional": true
		}
	},
	"packageManager": "bun@1.3.14",
	"volta": { "extends": "../../package.json" }
}
